# Factory AI Backend Configuration

# Database Configuration
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/factory_ai
DATABASE_ECHO=False

# API Configuration
API_TITLE=Factory AI Compliance Dashboard
API_VERSION=1.0.0

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Compliance Rule Thresholds
LONG_ABSENCE_THRESHOLD_MINUTES=120
REPEAT_VIOLATION_THRESHOLD=3
REPEAT_VIOLATION_DAYS=7
EARLY_EXIT_THRESHOLD_MINUTES=30
LATE_REPORTING_THRESHOLD_MINUTES=15
MIN_CONFIDENCE_SCORE=0.65
DUPLICATE_EVENT_COOLDOWN_SECONDS=30

# Alert Configuration
ALERT_EMAIL_ENABLED=False
ALERT_SMS_ENABLED=False
ALERT_DASHBOARD_ENABLED=True

# Application Settings
DEBUG=False
ENVIRONMENT=development
